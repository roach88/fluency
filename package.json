{
  "name": "flue-cloudflare-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A minimal Flue agent deployed on Cloudflare Workers using Cloudflare Workers AI.",
  "scripts": {
    "dev": "flue dev --target cloudflare --env .env",
    "build": "flue build --target cloudflare",
    "deploy": "flue build --target cloudflare && wrangler deploy --secrets-file .env",
    "typecheck": "tsc --noEmit",
    "flue:help": "flue --help",
    "cf:whoami": "wrangler whoami",
    "cf:r2:list": "wrangler r2 bucket list",
    "sandbox:check": "node -e \"console.log('@cloudflare/sandbox', require('./node_modules/@cloudflare/sandbox/package.json').version)\" && docker info >/dev/null",
    "kb:seed": "./scripts/seed-kb.sh",
    "kb:test": "curl http://localhost:3583/agents/support/kb-test-$(date +%s) -H \"Content-Type: application/json\" -d '{\"message\":\"What services does this Fluency agent use?\"}'",
    "kb:get-overview": "wrangler r2 object get fluency-knowledge-base/flue-cloudflare-overview.md --remote --pipe"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.9.2",
    "@flue/sdk": "^0.3.6",
    "agents": "^0.12.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@flue/cli": "^0.3.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0"
  }
}
