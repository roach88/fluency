# Cloudflare Workers AI credentials used by the Flue model provider.
# Create a scoped Cloudflare API token yourself; do not commit real values.
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_KEY="your-cloudflare-api-token"

# Optional future examples:
# - R2 knowledge-base support agent uses a wrangler R2 binding named KNOWLEDGE_BASE.
# - Cloudflare Sandbox assistant uses a Durable Object binding named Sandbox plus containers config.
# These are configured in wrangler.jsonc, not as secret env values.
